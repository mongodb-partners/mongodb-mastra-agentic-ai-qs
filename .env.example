# Marshal — environment
APP_NAME=Marshal
MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER/?retryWrites=true&w=majority
MONGODB_DB=marshal
VOYAGE_API_KEY=
# Optional: leave unset to use the MongoDB-hosted Voyage endpoint (https://ai.mongodb.com/v1)
VOYAGE_BASE_URL=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5
# Optional gateway routing for the LLM (Anthropic API root, e.g. .../anthropic/v1)
LLM_BASE_URL=
# Gateway key, sent as the `api-key` header when LLM_BASE_URL points at an APIM gateway
GROVE_API_KEY=
PORT=8000
RRF_K=60
# Synthetic decided-precedent corpus seeded at provision time (the scale story).
# 0 disables it; default 1200. Embedded in batches — ~13 Voyage calls at the default size.
SEED_SCALE_COUNT=1200
# Secrets (two, kept separate so neither can forge the other). A dev fallback is used only for
# non-production / demo runs; in production with the live agent these MUST be set or startup fails.
AUDIT_SECRET=      # HMAC secret for the tamper-evident audit chain
SESSION_SECRET=    # HMAC secret for session tokens (distinct from AUDIT_SECRET)
# DEMO_MODE=1      # replay a pre-baked run (no runtime LLM); default off = live agent
# NODE_ENV=production
